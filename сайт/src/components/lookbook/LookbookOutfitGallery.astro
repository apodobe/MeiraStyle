---
interface Props {
	images: string[];
	title: string;
	rootId: string;
	/** Глобальный индекс первого слайда в lightbox */
	lightboxStartIndex: number;
	lightboxId: string;
}

const { images, title, rootId, lightboxStartIndex, lightboxId } = Astro.props;
const multi = images.length > 1;
---

<div
	class="group/gallery relative mb-6"
	data-outfit-gallery
	data-gallery-id={rootId}
>
	<div
		class:list={[
			'relative overflow-hidden rounded-[var(--radius-md)] border border-line bg-cream-100',
			multi ? 'shadow-[var(--shadow-soft)]' : '',
		]}
	>
		<div class="relative aspect-[4/5] w-full sm:aspect-[5/6]">
			<div
				class:list={[
					'absolute inset-0 flex overflow-x-auto [-webkit-overflow-scrolling:touch] [scrollbar-width:none] [&::-webkit-scrollbar]:hidden',
					multi ? 'snap-x snap-mandatory touch-pan-y' : '',
				]}
				data-gallery-track
				tabindex={multi ? 0 : undefined}
				role={multi ? 'region' : undefined}
				aria-label={multi ? `Фото: ${title}` : undefined}
			>
				{
					images.map((src, index) => (
						<figure
							class:list={[
								'relative m-0 h-full w-full shrink-0',
								multi ? 'basis-full snap-center snap-always' : 'basis-full',
							]}
						>
							<button
								type="button"
								class="group/btn relative block h-full w-full cursor-zoom-in overflow-hidden"
								data-lightbox-open
								data-lightbox-target={lightboxId}
								data-lightbox-index={lightboxStartIndex + index}
								aria-label={`Увеличить: ${title}`}
							>
								<img
									src={src}
									alt={`${title}${multi ? ` — фото ${index + 1}` : ''}`}
									class="h-full w-full object-cover transition-transform duration-300 group-hover/btn:scale-[1.02]"
									loading={index === 0 ? 'eager' : 'lazy'}
									decoding="async"
									draggable="false"
								/>
								<span class="absolute bottom-3 right-3 rounded-full bg-ink/55 px-3 py-1 text-xs text-white backdrop-blur-sm">
									Увеличить
								</span>
							</button>
						</figure>
					))
				}
			</div>
		</div>

		{
			multi ? (
				<>
					<button
						type="button"
						class="absolute left-2 top-1/2 z-10 flex h-10 w-10 -translate-y-1/2 items-center justify-center rounded-full border border-line bg-white/90 text-lg text-ink shadow-sm transition-opacity hover:bg-white sm:left-3"
						data-gallery-prev
						aria-label="Предыдущее фото"
					>
						‹
					</button>
					<button
						type="button"
						class="absolute right-2 top-1/2 z-10 flex h-10 w-10 -translate-y-1/2 items-center justify-center rounded-full border border-line bg-white/90 text-lg text-ink shadow-sm transition-opacity hover:bg-white sm:right-3"
						data-gallery-next
						aria-label="Следующее фото"
					>
						›
					</button>
					<div
						class="absolute bottom-3 left-1/2 z-10 flex -translate-x-1/2 gap-1.5"
						data-gallery-dots
						role="tablist"
						aria-label="Номер фото"
					>
						{images.map((_, index) => (
							<button
								type="button"
								class="h-1.5 w-1.5 rounded-full bg-white/50 transition-all data-[active=true]:w-5 data-[active=true]:bg-white"
								data-gallery-dot
								data-index={index}
								role="tab"
								aria-label={`Фото ${index + 1}`}
								aria-selected={index === 0 ? 'true' : 'false'}
								data-active={index === 0 ? 'true' : 'false'}
							/>
						))}
					</div>
				</>
			) : null
		}
	</div>
</div>

<script>
	function initGallery(root: HTMLElement) {
		const track = root.querySelector<HTMLElement>('[data-gallery-track]');
		const slides = root.querySelectorAll<HTMLElement>('figure');
		if (!track || slides.length <= 1) return;

		const dots = root.querySelectorAll<HTMLButtonElement>('[data-gallery-dot]');

		function getWidth() {
			const first = slides[0];
			return first ? first.getBoundingClientRect().width : track.clientWidth;
		}

		function getIndex() {
			const w = getWidth();
			if (w <= 0) return 0;
			return Math.max(0, Math.min(slides.length - 1, Math.round(track.scrollLeft / w)));
		}

		function scrollTo(index: number) {
			const w = getWidth();
			track.scrollTo({
				left: index * w,
				behavior: window.matchMedia('(prefers-reduced-motion: reduce)').matches ? 'auto' : 'smooth',
			});
		}

		function sync() {
			const index = getIndex();
			dots.forEach((dot, i) => {
				const active = i === index;
				dot.dataset.active = active ? 'true' : 'false';
				dot.setAttribute('aria-selected', active ? 'true' : 'false');
			});
		}

		root.querySelector('[data-gallery-prev]')?.addEventListener('click', () => {
			scrollTo(Math.max(0, getIndex() - 1));
		});
		root.querySelector('[data-gallery-next]')?.addEventListener('click', () => {
			scrollTo(Math.min(slides.length - 1, getIndex() + 1));
		});

		dots.forEach((dot) => {
			dot.addEventListener('click', () => {
				const index = Number(dot.dataset.index ?? '0');
				scrollTo(index);
			});
		});

		let timer = 0;
		track.addEventListener('scroll', () => {
			window.clearTimeout(timer);
			timer = window.setTimeout(sync, 64);
		});

		track.addEventListener('keydown', (event) => {
			if (event.key === 'ArrowLeft') {
				event.preventDefault();
				scrollTo(Math.max(0, getIndex() - 1));
			} else if (event.key === 'ArrowRight') {
				event.preventDefault();
				scrollTo(Math.min(slides.length - 1, getIndex() + 1));
			}
		});
	}

	document.querySelectorAll<HTMLElement>('[data-outfit-gallery]').forEach(initGallery);
</script>
