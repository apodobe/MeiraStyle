{
  "name": "osipovastyle.ru",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "dev:api": "node scripts/dev-booking-api.cjs",
    "lookbook:placeholders": "node scripts/generate-lookbook-placeholders.mjs",
    "lookbook:prices": "node scripts/fetch-lookbook-prices.mjs",
