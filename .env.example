# Скопируйте в .env и заполните. Файл .env в git не коммитится.
#
# HTTPS: бесплатный сертификат (Let's Encrypt) включается в панели хостинга
# (у Hostland: раздел SSL / защищённое соединение для домена). Сначала выпустите
# сертификат, затем сделайте деплой — public/.htaccess отправит посетителей на https://.

FTP_HOST=ftp7.hostland.ru
FTP_USER=host1478177_osipovastyle
FTP_PASSWORD=

# Каталог относительно корня FTP-пользователя.
# У Hostland с включённым Node.js документ сайта — projects/htdocs (там server.js / Passenger).
# Исходник server.js в репозитории: deploy/server.js — после `npm run build` копируется в dist/ (не из public/).
# Статический сайт заливать туда же; корневой htdocs для домена часто не используется.
FTP_REMOTE_DIR=projects/htdocs

# Установите 1, чтобы видеть ответы сервера в логе
# FTP_VERBOSE=0

# Установите 0, если в htdocs должны остаться файлы, не из сборки (не очищать каталог перед upload)
# FTP_CLEAN_REMOTE=1

# Карточка «Следующая встреча»: строка «Планируют пойти: … - +N» подгружается с GET /api/meeting-attendees
# (имена и счётчик из успешных заявок через Node; файл data/booking-attendees.json рядом с server.js на хосте).

# SEO: коды подтверждения из кабинетов Яндекс.Вебмастер и Google Search Console (попадают в <meta> при сборке)
# PUBLIC_YANDEX_VERIFICATION=
# PUBLIC_GOOGLE_SITE_VERIFICATION=

# Записи на встречу — как capsulasna.ru: фронт шлёт POST на /api/meeting-booking.php;
# на Node-хостинге отвечает server.js (curl → Telegram, 15 с); при деплое в www/ без Node
# выполняется public/api/meeting-booking.php. Секреты для PHP: dist/api/meeting-booking.secrets.php (генерируется при сборке).
# На Node по умолчанию curl как в PHP/capsulasna. Только https: MEETING_BOOKING_USE_CURL=0
# Исходящий HTTP-прокси (CONNECT) к api.telegram.org — только если реально настроен (squid/3proxy ACL на api.telegram.org:443).
# Проверка: curl -v -x http://ХОСТ:ПОРТ https://api.telegram.org/ — должно быть 404/401, не «Proxy CONNECT aborted».
# TELEGRAM_HTTPS_PROXY=http://127.0.0.1:3128
#
# Telegram (@BotFather: токен; в git не коммитить).
# Получатель: chat_id пользователя или группы (число). Пользователь должен написать боту /start.
# Узнать chat_id: после /start откройте в браузере
# https://api.telegram.org/bot<TELEGRAM_BOT_TOKEN>/getUpdates и найдите "chat":{"id": ...}
# TELEGRAM_BOT_TOKEN=
# Имя бота для текста «откройте @…» (как в capsulasna для @capsulasnabot).
# TELEGRAM_BOT_USERNAME=meirastylebot
# Несколько получателей через запятую (user id / группа).
# TELEGRAM_BOOKING_CHAT_ID=123456789,987654321
# Локально без Telegram: пропустить отправку и показать QR (только для разработки).
# PUBLIC_MEETING_BOOKING_SKIP=1
# Порт локального API для astro dev (прокси в astro.config.mjs).
# MEETING_BOOKING_API_PORT=8787
